# ──────────────────────────────────────────────────────
# Variables de entorno para ReunionesAuto
# ──────────────────────────────────────────────────────
# Copia este archivo a .env y completa los valores.
# El backend carga .env desde la raíz del proyecto.

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# JWT – Clave secreta para firmar tokens (CAMBIAR EN PRODUCCIÓN)
SECRET_KEY=tu-clave-secreta-super-segura-y-larga

# Frontend URL (para CORS en producción)
FRONTEND_URL=https://tu-app.vercel.app

# Backend URL pública (para n8n callbacks)
BACKEND_PUBLIC_URL=https://reunionesauto.onrender.com

# n8n Webhooks
N8N_CREATE_MEETING_WEBHOOK_URL=https://tu-instancia-n8n.cloud/webhook/crear-reunion-chat
N8N_DRAFT_MEETING_WEBHOOK_URL=https://tu-instancia-n8n.cloud/webhook/borrador-reunion-chat
N8N_RESUMEN_VIRTUAL_WEBHOOK_URL=https://tu-instancia-n8n.cloud/webhook/resumen-virtual
N8N_RESUMEN_PRESENCIAL_WEBHOOK_URL=https://tu-instancia-n8n.cloud/webhook/resumen-presencial
N8N_PROCESS_RECORDING_WEBHOOK_URL=https://tu-instancia-n8n.cloud/webhook/procesar-resumen
N8N_CALLBACK_SECRET=un-secreto-largo-y-aleatorio
N8N_WORKFLOW_VERSION=unversioned

# Zoom Server-to-Server OAuth
ZOOM_ACCOUNT_ID=tu-zoom-account-id
ZOOM_CLIENT_ID=tu-zoom-client-id
ZOOM_CLIENT_SECRET=tu-zoom-client-secret

# LLM (Groq o OpenAI)
GROQ_API_KEY=tu-groq-api-key
# OPENAI_API_KEY=tu-openai-api-key  # Alternativa a Groq
