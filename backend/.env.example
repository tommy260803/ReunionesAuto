# ──────────────────────────────────────────────────────
# Variables de entorno para el backend de ReunionesAuto
# ──────────────────────────────────────────────────────
# Copia este archivo a ../.env (raíz del proyecto) y completa los valores.
# El backend carga el .env desde la raíz del proyecto (zoom2/.env).

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui

# n8n Webhooks
N8N_CREATE_MEETING_WEBHOOK_URL=https://tu-instancia-n8n/webhook/crear-reunion-chat
N8N_DRAFT_MEETING_WEBHOOK_URL=https://tu-instancia-n8n/webhook/borrador-reunion-chat
N8N_RESUMEN_VIRTUAL_WEBHOOK_URL=https://tu-instancia-n8n/webhook/resumen-virtual
N8N_RESUMEN_PRESENCIAL_WEBHOOK_URL=https://tu-instancia-n8n/webhook/resumen-presencial

# JWT – Clave secreta para firmar tokens (CAMBIAR EN PRODUCCIÓN)
SECRET_KEY=tu-clave-secreta-super-segura
