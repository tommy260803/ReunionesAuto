      "name": "Preparar contexto"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer TU_GROQ_API_KEY_AQUI"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un asistente que genera res\\u00famenes profesionales de reuniones presenciales en espa\\u00f1ol a partir del acta escaneada.\\n\\nGenera un resumen estructurado con:\\n1. Datos de la reuni\\u00f3n (tema, fecha, duraci\\u00f3n, tipo)\\n2. Temas tratados (basados en el acta)\\n3. Acuerdos y conclusiones\\n4. Tareas y responsables\\n5. Pr\\u00f3ximos pasos\\n\\nDevuelve SOLO JSON v\\u00e1lido sin texto adicional:\\n{\\n  \\\"resumen\\\": \\\"texto completo del resumen\\\",\\n  \\\"temas_tratados\\\": [\\\"tema 1\\\", \\\"tema 2\\\"],\\n  \\\"acuerdos\\\": [\\\"acuerdo 1\\\", \\\"acuerdo 2\\\"],\\n  \\\"tareas\\\": [\\\"tarea 1\\\", \\\"tarea 2\\\"]\\n}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.contexto) }}\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        96,
        -240
      ],
      "id": "p6",
      "name": "Groq API"
    },
    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst content = groqResponse.choices[0].message.content;\nconst parsed = typeof content === 'string' ? JSON.parse(content) : content;\n\nconst resumenTexto = parsed.resumen || JSON.stringify(parsed);\nconst reunionId = $('Preparar contexto').first().json.reunion_id;\n\nreturn [{ json: { resumen: resumenTexto, reunion_id: reunionId } }];"
      },
