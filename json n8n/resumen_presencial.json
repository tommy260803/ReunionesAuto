    {
      "parameters": {
        "jsCode": "const reunion = $('Obtener reuni\u00f3n').first().json;\nconst pdfData = $('Extraer texto del PDF').first().json;\n\nconst fecha = reunion.fecha_inicio ? new Date(reunion.fecha_inicio).toLocaleString('es-PE', { timeZone: 'America/Lima' }) : 'No especificada';\nconst pdfText = (pdfData.text || pdfData.extractedText || pdfData.content || '').substring(0, 15000);\n\nconst contexto = `Reuni\u00f3n: ${reunion.tema || 'Sin tema'}\nFecha: ${fecha}\nDuraci\u00f3n: ${reunion.duracion_minutos || 'No especificada'} minutos\nTipo: ${reunion.tipo || 'No especificado'}\n\nContenido del acta PDF:\n${pdfText || '(No se pudo extraer texto del PDF)'}`;\n\nconst reunionId = $('Webhook').first().json.body.reunion_id;\n\nreturn [{ json: { contexto: contexto, reunion_id: reunionId } }];"
      },
