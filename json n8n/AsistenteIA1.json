    {
      "parameters": {
        "jsCode": "const correos = $('Code in JavaScript').first().json.correos || [];\n\n// Siempre emitir al menos un item para que Merge no detenga el workflow.\nif (!Array.isArray(correos) || correos.length === 0) {\n  return [{ json: {} }];\n}\n\nreturn correos.map(correo => ({\n  json: {\n    correo: correo.trim().toLowerCase(),\n    id: null,\n    rol: 'participante'\n  }\n}));"
      },
