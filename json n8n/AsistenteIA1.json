    {
      "parameters": {
        "jsCode": "const request = $('Code in JavaScript').first().json;\nconst recipients = new Map();\n\nconst addRecipient = (correo, usuarioId, rol = 'participante') => {\n  if (!correo) return;\n  const key = correo.trim().toLowerCase();\n  const existing = recipients.get(key);\n  recipients.set(key, {\n    correo: key,\n    usuario_id: usuarioId || existing?.usuario_id || null,\n    rol: rol === 'organizador' ? 'organizador' : (existing?.rol || 'participante')\n  });\n};\n\n// El creador siempre queda registrado, incluso si no hay invitados externos.\naddRecipient(request.creador_correo, request.creador_id, 'organizador');\n\nfor (const item of $input.all().map(i => i.json)) {\n  addRecipient(item?.correo, item?.id || item?.usuario_id, item?.rol || 'participante');\n}\n\nreturn [{ json: { invitados_finales: [...recipients.values()] } }];\n"
      },
