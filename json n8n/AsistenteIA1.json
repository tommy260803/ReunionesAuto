        "jsCode": "const correos = $('Code in JavaScript').first().json.correos || [];\n\nif (!Array.isArray(correos) || correos.length === 0) {\n  return [];\n}\n\nreturn correos.map(correo => ({\n  json: {\n    correo: correo.trim().toLowerCase(),\n    id: null\n  }\n}));"
