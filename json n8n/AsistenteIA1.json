    {
      "parameters": {
        "jsCode": "const rawResponse = $input.first().json;\nconst draft = $('Code in JavaScript').first().json;\nconst zoom = $('Create a meeting').first().json;\nconst recipients = $('Code in JavaScript1').first().json.invitados_finales || [];\n\n// PostgREST puede devolver el registro directamente, dentro de data/body o como array.\nconst findMeeting = (value) => {\n  if (Array.isArray(value)) return value.map(findMeeting).find(Boolean) || null;\n  if (!value || typeof value !== 'object') return null;\n  if (value.id || value.tema || value.fecha_inicio) return value;\n  for (const nested of Object.values(value)) {\n    const found = findMeeting(nested);\n    if (found) return found;\n  }\n  return null;\n};\n\nconst persisted = findMeeting(rawResponse) || {};\n\nreturn [{\n  json: {\n    estado: 'confirmada',\n    respuesta: 'Reunión creada correctamente.',\n    meeting: {\n      id: persisted.id || null,\n      tema: persisted.tema || draft.asunto,\n      fecha_inicio: persisted.fecha_inicio || draft.fecha_iso,\n      duracion_minutos: Number(persisted.duracion_minutos || draft.duracion_minutos || 60),\n      tipo: persisted.tipo || draft.tipo || 'virtual',\n      direccion: persisted.direccion || draft.direccion || null,\n      join_url: zoom.join_url || persisted.join_url || ''\n    },\n    destinatarios: recipients\n  }\n}];"
      },
