    {
      "parameters": {
        "jsCode": "const data = $input.all().flatMap(i => i.json);\n\n// Convertir todo a lista de {correo, usuario_id}\nconst inviteList = data\n  .filter(i => i?.correo)\n  .map(i => ({\n    correo: i.correo.trim().toLowerCase(),\n    usuario_id: i.id || null   // <-- IMPORTANTE: aquí tomamos el ID si existe\n  }));\n\n// Eliminar duplicados por correo\nconst unique = [];\nconst seen = new Set();\n\nfor (const item of inviteList) {\n  if (!seen.has(item.correo)) {\n    seen.add(item.correo);\n    unique.push(item);\n  }\n}\n\n// Salida final en UN solo item\nreturn [{\n  json: {\n    invitados_finales: unique\n  }\n}];\n"
