        "options": {
          "rawBody": "={\n  \"creador_id\": \"UUID-de-usuarios.id\",\n  \"mensaje\": \"Programa una reunión mañana a las 11am por 60 minutos con asunto Ventas Q4 e invita a pro o superior y a ana@empresa.com\"\n}\n"
        }
