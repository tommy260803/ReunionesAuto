    {
      "parameters": {
        "jsCode": "const invitados = $('Code in JavaScript1').first().json.invitados_finales;\n\nif (!Array.isArray(invitados)) {\n  throw new Error(\"No se encontró invitados_finales o no es un array\");\n}\n\n// El organizador ya conoce la reunión; solo se envían correos a invitados externos.\nreturn invitados\n  .filter(inv => inv.rol !== 'organizador')\n  .map(inv => ({ json: { correo: inv.correo } }));\n"
      },
